{
  "version": 2,
  "buildCommand": "hugo --gc --minify --baseURL https://www.rgn.biz.id/",
  "outputDirectory": "public",
  "framework": "hugo",
  "installCommand": "",
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/blog",
      "destination": "/blog/"
    },
    {
      "source": "/blog/:path*",
      "destination": "/blog/:path*/"
    }
  ],
  "redirects": [
    {
      "source": "/blog/index.html",
      "destination": "/blog/",
      "permanent": true
    }
  ]
}